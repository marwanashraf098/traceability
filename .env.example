# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Traced production environment variables
#
# Copy this file to .env and fill in real values before deploying.
# .env is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase / Postgres ───────────────────────────────────────────────────────

# App datasource — connects as app_user (RLS enforced). Use session-mode pooler
# port 5432, NOT transaction-mode port 6543 (SET LOCAL is reset at 6543 → silent
# zero-row results under RLS).
DATABASE_URL=jdbc:postgresql://aws-0-eu-west-1.pooler.supabase.com:5432/postgres?user=app_user.YOUR_PROJECT_REF&password=PLACEHOLDER&sslmode=require

# RLS-enforced app role credentials (must match the DATABASE_URL above)
APP_DB_USER=app_user.YOUR_PROJECT_REF
APP_DB_PASSWORD=PLACEHOLDER

# Flyway DDL datasource — uses postgres/owner role for schema migrations.
# Can be the same pooler URL with postgres credentials, or the direct host
# (db.YOUR_PROJECT_REF.supabase.co:5432) if available on your plan.
FLYWAY_DB_URL=jdbc:postgresql://aws-0-eu-west-1.pooler.supabase.com:5432/postgres?user=postgres.YOUR_PROJECT_REF&password=PLACEHOLDER&sslmode=require
FLYWAY_DB_USER=postgres.YOUR_PROJECT_REF
FLYWAY_DB_PASSWORD=PLACEHOLDER

# ── JWT + Encryption ─────────────────────────────────────────────────────────

# JWT signing secret. Base64-encoded, minimum 32 bytes.
# Generate: openssl rand -base64 32
JWT_SECRET=PLACEHOLDER_base64_32_bytes_minimum

# AES-256-GCM envelope key for encrypting Shopify/Bosta API tokens at rest.
# Must be exactly 32 bytes, base64-encoded.
# Generate: openssl rand -base64 32 | head -c 44  (44 chars = 32 bytes base64)
APP_ENCRYPTION_KEY=PLACEHOLDER_base64_exactly_32_bytes

# ── Shopify OAuth app ─────────────────────────────────────────────────────────

# From Shopify Partner Dashboard → Apps → your app → API credentials
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret

# These must match the values registered in the Shopify Partner Dashboard.
# Replace YOUR_DOMAIN with the actual domain (same as nginx server_name).
SHOPIFY_REDIRECT_URI=https://YOUR_DOMAIN/auth/shopify/callback
SHOPIFY_APP_URL=https://YOUR_DOMAIN
SHOPIFY_WEBHOOK_BASE_URL=https://YOUR_DOMAIN

# Shopify API version — bump here + re-register webhooks when upgrading.
SHOPIFY_API_VERSION=2026-04

# ── Bosta ─────────────────────────────────────────────────────────────────────

# Base URL for Bosta API. Production default is correct; only change for staging.
# Per-tenant API keys are stored encrypted in the database — not an env var.
BOSTA_BASE_URL=https://app.bosta.co

# ── Sentry (optional — Sentry is disabled when DSN is empty) ──────────────────

# DSN from Sentry project settings → Client Keys. Leave empty to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
